# Kamatera / production — copy to the server as backend/.env
#   cp .env.production.example .env
#   chmod 600 .env
#   nano .env   (set secrets; never commit .env)
#
# Do not copy your laptop backend/.env — use new DJANGO_SECRET_KEY and production values.

DJANGO_SECRET_KEY="change-me-generate-with-python-secrets-token_urlsafe"
DJANGO_DEBUG=False
# Public IP + domain when DNS is ready (comma-separated, no spaces)
DJANGO_ALLOWED_HOSTS=203.0.113.50,defensys.yourdomain.edu

POSTGRES_DB=defensys_db
POSTGRES_USER=defensys
POSTGRES_PASSWORD="change-me-match-server-postgres-user"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DJANGO_TEST_USE_POSTGRES=False

# File storage on AWS S3 (recommended for Kamatera)
USE_S3=True
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-1
AWS_QUERYSTRING_EXPIRE=3600
