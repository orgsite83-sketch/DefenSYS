# First-time setup: copy this file to .env and edit values.
#   Windows (cmd):   copy .env.example .env
#   PowerShell:      Copy-Item .env.example .env
#   macOS / Linux:   cp .env.example .env
# Never commit .env — it is listed in backend/.gitignore.
# Use quotes if the key contains = or spaces
DJANGO_SECRET_KEY="change-me-to-a-long-random-string"
DJANGO_DEBUG=True
# Include 10.0.2.2 for Android emulator; add your PC LAN IP for physical devices on Wi-Fi.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,192.168.1.67

POSTGRES_DB=defensys_db
POSTGRES_USER=defensys
# Quote the value if it contains @ or =
POSTGRES_PASSWORD="change-me"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Tests use SQLite in backend/.tmp/ by default (no Postgres CREATEDB needed).
# Set to true only if your DB user can create test databases.
DJANGO_TEST_USE_POSTGRES=False

# Object storage: false = local backend/media/ (default for localhost)
# Vault PDFs (new uploads): media/vault_entries/{pit|capstone}/{year-level}/{academic_year}/{MM}/filename.pdf
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-1
# Optional custom endpoint (MinIO, LocalStack)
# AWS_S3_ENDPOINT_URL=
# Presigned download URL lifetime (seconds)
AWS_QUERYSTRING_EXPIRE=3600
