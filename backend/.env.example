# First-time setup: copy this file to .env and edit values.
#   Windows (cmd):   copy .env.example .env
#   PowerShell:      Copy-Item .env.example .env
#   macOS / Linux:   cp .env.example .env
# Never commit .env — it is listed in backend/.gitignore.
# Use quotes if the key contains = or spaces
DJANGO_SECRET_KEY="change-me-to-a-long-random-string"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=defensys_db
POSTGRES_USER=defensys
# Quote the value if it contains @ or =
POSTGRES_PASSWORD="change-me"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: prototype/demo API helpers (default off)
ENABLE_PROTOTYPE_TOOLS=False
